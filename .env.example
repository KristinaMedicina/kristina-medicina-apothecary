# Kristina Medicina Apothecary — environment configuration
# Copy this file to `.env.local` and fill in values as you connect each tool.
# Everything is optional: the site builds and runs with no values set.

# ----------------------------------------------------------------------------
# Stripe Payment Links (product checkout)
# Create a Payment Link per product in the Stripe Dashboard, then paste the URL.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_TALLOW=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_FACIAL_OIL=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_CYCLE_TEA=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_CACAO=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_TINCTURE=

# Legacy aliases (still supported)
NEXT_PUBLIC_STRIPE_LINK_TALLOW_BALM=
NEXT_PUBLIC_STRIPE_LINK_FACIAL_OIL=
NEXT_PUBLIC_STRIPE_LINK_CYCLE_TEA=
NEXT_PUBLIC_STRIPE_LINK_CACAO=
NEXT_PUBLIC_STRIPE_LINK_TINCTURE=

# ----------------------------------------------------------------------------
# Calendly (consultation booking + payment)
# Set one scheduling URL per consultation. NEXT_PUBLIC_CALENDLY_URL is a fallback.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_CALENDLY_BOTANICAL=
NEXT_PUBLIC_CALENDLY_CACAO=
NEXT_PUBLIC_CALENDLY_INTEGRATION=

# Legacy aliases (still supported)
NEXT_PUBLIC_CALENDLY_BOTANICAL_WELLNESS=
NEXT_PUBLIC_CALENDLY_CEREMONIAL_CACAO=
NEXT_PUBLIC_CALENDLY_PREPARATION_INTEGRATION=

# ----------------------------------------------------------------------------
# MailerLite (primary email provider for /api/subscribe)
# Both values are required for newsletter signups to succeed.
# ----------------------------------------------------------------------------
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# ----------------------------------------------------------------------------
# Kit / ConvertKit (alternative email provider)
# NEXT_PUBLIC_KIT_FORM_ID enables the embed; KIT_API_SECRET powers /api/subscribe.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_KIT_FORM_ID=
KIT_API_SECRET=

# ----------------------------------------------------------------------------
# Klaviyo (alternative email provider)
# Public key is used client-side; private key + list id power /api/subscribe.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
KLAVIYO_LIST_ID=
KLAVIYO_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Google Analytics 4 (loaded only after cookie consent)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=

# ----------------------------------------------------------------------------
# Deferred (post-revenue) — not wired up yet, kept for future use
# ----------------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_SHOPIFY_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=
